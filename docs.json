          "href": "/api-reference",
          "icon": "code"
        }
      ]
    },
    "dropdowns": [
      {
        "dropdown": "Documentation",
        "icon": "book",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "concepts",
              "coverage"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/kyb-onboarding",
              "guides/recipients",
              "guides/payment-methods",
              "guides/fiat-to-fiat-payout",
              "guides/stablecoin-transfer",
              "guides/crypto-payout",
              "guides/webhooks"
            ]
          }
        ]
      },
      {
        "dropdown": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "Users",
            "pages": ["api-reference/users/me", "api-reference/users/sync"]
          },
          {
            "group": "Businesses",
            "pages": [
              "api-reference/businesses/create",
              "api-reference/businesses/get"
            ]
          },
          {
