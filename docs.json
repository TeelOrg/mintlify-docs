          },
          {
            "group": "Payment Methods",
            "pages": [
              "api-reference/payment-methods/requirements",
              "api-reference/payment-methods/list",
              "api-reference/payment-methods/get",
              "api-reference/payment-methods/create",
              "api-reference/payment-methods/delete"
            ]
          },
          {
            "group": "Quotes",
            "pages": [
              "api-reference/quotes/fiat-to-fiat-best",
              "api-reference/quotes/fiat-to-fiat-all",
