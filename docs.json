{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Teel API",
  "description": "Cross-border payment and stablecoin transfer platform API documentation",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.png",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.teel.finance"
    }
  },
  "navigation": {
    "global": {
      "tabs": [
        {
          "tab": "Documentation",
          "href": "/",
          "icon": "book"
        },
        {
          "tab": "API Reference",
          "href": "/api-reference",
          "icon": "code"
        }
      ]
    },
    "dropdowns": [
      {
        "dropdown": "Documentation",
        "icon": "book",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "authentication"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/fiat-to-fiat-payout",
              "guides/stablecoin-transfer",
              "guides/crypto-payout",
              "guides/kyb-onboarding"
            ]
          }
        ]
      },
      {
        "dropdown": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "Payouts",
            "pages": [
              "api-reference/payouts/list",
              "api-reference/payouts/get",
              "api-reference/payouts/create",
              "api-reference/payouts/update",
              "api-reference/payouts/delete"
            ]
          },
          {
            "group": "Recipients",
            "pages": [
              "api-reference/recipients/list",
              "api-reference/recipients/get",
              "api-reference/recipients/create",
              "api-reference/recipients/update",
              "api-reference/recipients/delete"
            ]
          },
          {
            "group": "Payment Methods",
            "pages": [
              "api-reference/payment-methods/list",
              "api-reference/payment-methods/get",
              "api-reference/payment-methods/requirements",
              "api-reference/payment-methods/create",
              "api-reference/payment-methods/delete"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/overview",
              "api-reference/webhooks/transfi",
              "api-reference/webhooks/pdax",
              "api-reference/webhooks/conduit",
              "api-reference/webhooks/airwallex",
              "api-reference/webhooks/borderless",
              "api-reference/webhooks/onrampmoney",
              "api-reference/webhooks/luno"
            ]
          }
        ]
      }
    ]
  }
}
