{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Teel API",
  "description": "Cross-border payment and stablecoin transfer platform API documentation",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.png",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Home Page",
      "href": "https://teel.finance"
    }
  },
  "navigation": {
    "global": {
      "tabs": [
        {
          "tab": "Documentation",
          "href": "/",
          "icon": "book"
        },
        {
